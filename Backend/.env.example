# Database Connection String
# Example: postgresql://postgres:password@localhost:5432/floodsense
DATABASE_URL=postgresql://postgres:password@localhost:5432/floodsense

# JWT Secret for authentication tokens
# You can generate a random string using: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_here

# AI Service API Key (if applicable, e.g., OpenAI, Claude)
# AI_SERVICE_API_KEY=your_ai_api_key_here

# Optional: Port for the backend server (default is 5000)
PORT=5000
